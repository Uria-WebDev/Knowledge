{% extends 'base.html.twig' %}

{% block title %}Knowledge - {{ cursus.name }}{% endblock %}

{% block lesson %}
<div class="container">

    <h1 class="margin-top-3 margin-bottom-3">
        Nos Leçons pour le Cursus : {{ cursus.name }}
    </h1>

    <div class="row">
        {% for lesson in lesson %}
        <div class="col-md-6 mb-3">
            <a href="{{ path('lesson_read', {id: lesson.id}) }}"
            class="card text-center padding-top-10 padding-bottom-10 background-darkblue background-blue-hov decoration-none">
                <div class="card-body text-center">
                    <h5>{{ lesson.name }}</h5>
                    <p>{{ lesson.price }} €</p>
                </div>
            </a>
        </div>
        {% else %}
        <p>Aucune leçon disponible pour ce cursus.</p>
        {% endfor %}
    </div>

</div>
{% endblock %}