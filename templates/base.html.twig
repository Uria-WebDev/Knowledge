<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <title>{% block title %}Knowledge{% endblock %}</title>

    {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
  </head>
  <body>
    {% block body %}
      <!-- HEADER -->
      <header class="border-bottom-dark background-white sticky">
          <div class="container">
              <div class="row justify-content-between align-items-center">
                  <div class="col-md-7">
                      <!-- Logo -->
                      <a href="/">
                          <img src="{{ asset('img/logo.jpeg') }}" alt="Logo de Knowledge" width="100"></img>
                      </a>
                  </div>

                  <!-- Barre de navigation -->
                  <div class="col-md-5">
                      <nav class="row text-center">
                        {% if is_granted('IS_AUTHENTICATED_FULLY') %}

                            <!-- Utilisateur connecté -->
                            <a href="{{ path('app_home') }}" class="col-md decoration-none decoration-hov
                            {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">
                                Accueil
                            </a>

                            <form id="logout-form" action="{{ path('app_logout') }}" method="post" style="display: none;">
                                <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
                            </form>
                            <a href="#" class="col-md decoration-none decoration-hov" onclick="event.preventDefault(); document.getElementById('logout-form').submit();">
                                Se déconnecter
                            </a>
                        {% else %}
                        
                            <!-- Utilisateur déconnecté -->
                            <a href="{{ path('app_home') }}" class="col-md decoration-none decoration-hov
                            {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">
                                Accueil
                            </a>

                            <a href="{{ path('app_login') }}" class="col-md decoration-none decoration-hov
                            {{ app.request.attributes.get('_route') == 'app_login' ? 'active' : '' }}">
                                Connection
                            </a>

                            <a href="{{ path('app_register') }}" class="col-md decoration-none decoration-hov
                            {{ app.request.attributes.get('_route') == 'app_register' ? 'active' : '' }}">
                                Inscription
                            </a>
                        {% endif %}
                      </nav>
                  </div>
              </div>
          </div>
      </header>

      <main class="container margin-top-20">
        {% block home %}{% endblock %} <!-- Page d'accueil -->

        {% block cursus %}{% endblock %} <!-- Page des cursus/thèmes -->

        {% block login %}{% endblock %} <!-- Page de connection -->
        {% block register %}{% endblock %} <!-- Page d'inscription -->
        {% block admin %}{% endblock %} <!-- Page Back Office -->
        {% block adminform %}{% endblock %} <!-- Page d'ajout de produit -->
        {% block paymentSuccess %}{% endblock %} <!-- Page de confirmation de payement -->
        {% block paymentCancel %}{% endblock %} <!-- Page d'annulation de payement -->
      </main>
    {% endblock %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  </body>
</html>