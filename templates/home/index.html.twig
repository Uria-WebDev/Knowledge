{% extends 'base.html.twig' %}

{% block title %}Knowledge - Accueil{% endblock %}

{% block home %}
<div class="container">
    <h1 class="margin-top-3 margin-bottom-3">Nos Formations par Thèmes :</h1>

    <div class="row">
    {% for theme in themes %}
        <div class="col-md-6 mb-3">
            <a href="{{ path('theme_cursus', {id: theme.id}) }}"
            class="card text-center padding-top-10 padding-bottom-10 background-darkblue background-blue-hov decoration-none">
                <div class="card-body">
                    <h5 class="card-title">{{ theme.name }}</h5>
                </div>
            </a>
        </div>
    {% endfor %}
    </div>
</div>
{% endblock %}
